<Window x:Class="PdfToolbox.AddTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Texto" Height="280" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Texto a inserir:" FontWeight="SemiBold" Grid.Row="0"/>
        <TextBox x:Name="TxtContent" Grid.Row="1" Margin="0,5,0,10" Height="50" TextWrapping="Wrap" AcceptsReturn="True"/>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Fonte:" FontWeight="SemiBold"/>
                <ComboBox x:Name="CmbFont" SelectedIndex="0" Margin="0,5,0,0">
                    <ComboBoxItem Content="Helvetica"/>
                    <ComboBoxItem Content="Times Roman"/>
                    <ComboBoxItem Content="Courier"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Tamanho:" FontWeight="SemiBold"/>
                <TextBox x:Name="TxtSize" Text="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Cor (Hexadecimal ou Nome):" FontWeight="SemiBold"/>
            <TextBox x:Name="TxtColor" Text="Black" Margin="0,5,0,0" ToolTip="Exemplo: Red, Blue, #FF0000"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancelar" Width="80" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Content="Próximo (Posicionar...)" Width="150" Background="#0078D7" Foreground="White" Click="BtnApply_Click"/>
        </StackPanel>
    </Grid>
</Window>
