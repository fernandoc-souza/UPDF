<Window x:Class="PdfToolbox.SignaturePlacementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desenhe o local da Assinatura" Height="800" Width="600"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Clique e arraste na imagem para desenhar o retângulo onde a assinatura ficará." FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#333" TextWrapping="Wrap"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="-" Width="30" Click="BtnZoomOut_Click"/>
                    <TextBlock x:Name="TxtZoom" Text="100%" VerticalAlignment="Center" Margin="5,0" Width="40" TextAlignment="Center"/>
                    <Button Content="+" Width="30" Click="BtnZoomIn_Click" Margin="0,0,20,0"/>

                    <Button Content="Primeira Página" Width="100" Margin="0,0,5,0" Click="BtnFirst_Click"/>
                    <Button Content="Página Anterior" Width="100" Margin="0,0,5,0" Click="BtnPrev_Click"/>
                    <TextBlock x:Name="TxtPageInfo" Text="Página 1 / 1" VerticalAlignment="Center" Margin="5,0"/>
                    <Button Content="Próxima Página" Width="100" Margin="5,0,5,0" Click="BtnNext_Click"/>
                    <Button Content="Última Página" Width="100" Margin="0,0,0,0" Click="BtnLast_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="PageScrollViewer" Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="DarkGray" PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel">
            <Border BorderBrush="Black" BorderThickness="1" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <Border.LayoutTransform>
                    <ScaleTransform x:Name="PageScaleTransform" ScaleX="1.0" ScaleY="1.0" />
                </Border.LayoutTransform>
                <Canvas x:Name="PdfCanvas" Background="Transparent" MouseLeftButtonDown="PdfCanvas_MouseLeftButtonDown" MouseMove="PdfCanvas_MouseMove" MouseLeftButtonUp="PdfCanvas_MouseLeftButtonUp">
                    <Image x:Name="PdfImage" Stretch="None"/>
                    <Rectangle x:Name="SelectionRect" Stroke="Red" StrokeThickness="2" StrokeDashArray="2 2" Fill="#44FF0000" Visibility="Collapsed"/>
                </Canvas>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Cancelar" Width="100" Margin="0,0,10,0" Padding="5" Click="BtnCancel_Click"/>
            <Button Content="Confirmar" Width="100" Padding="5" Click="BtnConfirm_Click" IsDefault="True"/>
        </StackPanel>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#80000000" Visibility="Hidden">
            <TextBlock x:Name="LoadingText" Text="Carregando página..." Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
