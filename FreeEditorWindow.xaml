<Window x:Class="PdfToolbox.FreeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editor Livre - Marca-Texto e Caixas de Texto" Height="800" Width="1200"
        WindowStartupLocation="CenterOwner" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#D3D3D3" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <ToggleButton x:Name="BtnToolSelect" Content="Mover/Selecionar" Margin="0,0,5,0" Width="120" Click="Tool_Click" IsChecked="True"/>
                    <ToggleButton x:Name="BtnToolHighlight" Content="Marca-Texto" Margin="0,0,5,0" Width="100" Click="Tool_Click"/>
                    <ComboBox x:Name="CmbHighlightColor" Width="80" Margin="0,0,10,0" VerticalAlignment="Center" SelectedIndex="0">
                        <ComboBoxItem Content="Amarelo" Tag="#66FFFF00" Background="Yellow"/>
                        <ComboBoxItem Content="Verde" Tag="#6600FF00" Background="LightGreen"/>
                        <ComboBoxItem Content="Rosa" Tag="#66FF00FF" Background="Pink"/>
                        <ComboBoxItem Content="Azul" Tag="#6600FFFF" Background="LightBlue"/>
                    </ComboBox>
                    <ToggleButton x:Name="BtnToolEraser" Content="Borracha" Margin="0,0,10,0" Width="80" Click="Tool_Click"/>
                    <ToggleButton x:Name="BtnToolText" Content="Texto" Margin="0,0,5,0" Width="80" Click="Tool_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                    <Button Content="-" Width="30" Click="BtnZoomOut_Click"/>
                    <TextBlock x:Name="TxtZoom" Text="100%" VerticalAlignment="Center" Margin="5,0" Width="40" TextAlignment="Center"/>
                    <Button Content="+" Width="30" Click="BtnZoomIn_Click" Margin="0,0,20,0"/>

                    <Button Content="Página Anterior" Width="100" Margin="0,0,5,0" Click="BtnPrev_Click"/>
                    <TextBlock x:Name="TxtPageInfo" Text="Página 1 / 1" VerticalAlignment="Center" Margin="5,0"/>
                    <Button Content="Próxima Página" Width="100" Margin="0,0,0,0" Click="BtnNext_Click"/>
                </StackPanel>
                
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <Button Content="Excluir" x:Name="BtnDeleteSelected" Width="80" Margin="0,0,10,0" Click="BtnDeleteSelected_Click" IsEnabled="False" Foreground="Red"/>
                    <Button Content="Salvar" Width="100" Click="BtnConfirmSave_Click" FontWeight="Bold" Background="#28a745" Foreground="White"/>
                </StackPanel>

                <!-- Barra de Formatação de Texto -->
                <StackPanel x:Name="PnlTextFormat" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Background="#EAEAEA" Margin="5" Visibility="Visible">
                    <TextBlock Text="Fonte:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CmbFontFamily" Width="150" Margin="0,0,15,0" VerticalAlignment="Center" SelectionChanged="TextFormat_Changed"/>
                    
                    <TextBlock Text="Tamanho:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CmbFontSize" Width="60" Margin="0,0,15,0" VerticalAlignment="Center" SelectionChanged="TextFormat_Changed" IsEditable="True" TextBoxBase.TextChanged="CmbFontSize_TextChanged">
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="12"/>
                        <ComboBoxItem Content="14"/>
                        <ComboBoxItem Content="16"/>
                        <ComboBoxItem Content="18"/>
                        <ComboBoxItem Content="24"/>
                        <ComboBoxItem Content="36"/>
                        <ComboBoxItem Content="48"/>
                        <ComboBoxItem Content="72"/>
                    </ComboBox>
                    
                    <TextBlock Text="Cor:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="CmbTextColor" Width="100" Margin="0,0,15,0" VerticalAlignment="Center" SelectionChanged="TextFormat_Changed">
                        <ComboBoxItem Content="Preto" Tag="#FF000000" Background="Black" Foreground="White" IsSelected="True"/>
                        <ComboBoxItem Content="Vermelho" Tag="#FFFF0000" Background="Red" Foreground="White"/>
                        <ComboBoxItem Content="Azul" Tag="#FF0000FF" Background="Blue" Foreground="White"/>
                        <ComboBoxItem Content="Verde" Tag="#FF008000" Background="Green" Foreground="White"/>
                        <ComboBoxItem Content="Branco" Tag="#FFFFFFFF" Background="White" Foreground="Black"/>
                    </ComboBox>

                    <TextBlock Text="Transparência:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Slider x:Name="SldTextOpacity" Width="100" Minimum="0.1" Maximum="1.0" Value="1.0" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="TextFormat_Changed"/>
                    <TextBlock x:Name="TxtOpacityValue" Text="100%" VerticalAlignment="Center" Margin="5,0,0,0" Width="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="PageScrollViewer" Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="DarkGray" PreviewMouseWheel="PageScrollViewer_PreviewMouseWheel">
            <Border BorderBrush="Black" BorderThickness="1" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                <Border.LayoutTransform>
                    <ScaleTransform x:Name="PageScaleTransform" ScaleX="1.0" ScaleY="1.0" />
                </Border.LayoutTransform>
                <Canvas x:Name="PdfCanvas" Background="Transparent" 
                        MouseLeftButtonDown="PdfCanvas_MouseLeftButtonDown" 
                        MouseMove="PdfCanvas_MouseMove" 
                        MouseLeftButtonUp="PdfCanvas_MouseLeftButtonUp">
                    <Image x:Name="PdfImage" Stretch="None"/>
                    <Rectangle x:Name="DrawingRect" Stroke="Blue" StrokeThickness="1" StrokeDashArray="2 2" Fill="Transparent" Visibility="Collapsed"/>
                </Canvas>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#80000000" Visibility="Hidden">
            <TextBlock x:Name="LoadingText" Text="Carregando página..." Foreground="White" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
